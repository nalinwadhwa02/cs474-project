erms":{}},{"lemma":"log_2_16","terms":{}},{"lemma":"log_four_to_base_two","terms":{"y":"Ln(n) / Ln(4)"}},{"lemma":"log_of_quotient","terms":{"x":"n"}},{"lemma":"log_two_eq_8_implies_n","terms":{"n":"n"}},{"lemma":"decimal_digit_sum_256","terms":{}}]}
