  "lemmas": [
    {
      "name": "amgm_cubic_local",
      "english": "For nonnegative reals u,v, one has u^2*v <= (2*u^2 + v^2)/3.",
      "vars": [
        {
          "name": "u",
          "sort": "Real"
        },
        {
          "name": "v",
          "sort": "Real"
        }
      ],
      "body": "Implies(And(u >= 0, v >= 0), u*u*v <= (2*u*u + v*v)/3)"
    },
