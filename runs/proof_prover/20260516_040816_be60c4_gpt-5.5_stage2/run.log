      ],
      "body": "Implies(And((p * (A**2 + B**2) - A * B) * (s + t - s * t) != 0, u * (A + s * (p * B - A)) == A + v * (t * p * B - A), B + u * (s * p * A - B) == v * (B + t * (p * A - B))), And(u * (s + t - s * t) == t, v * (s + t - s * t) == s))"
